function pwm_sat = saturar_pwm_abs(pwm_cmd, pwm_min, pwm_max)
    pwm_sat = max(pwm_min, min(pwm_max, pwm_cmd));
end

function [Ts_5, Tr_10_90, Mp, essp, yss_sim] = metricas_respuesta(t, y, yss_teorico)

    t = t(:);
    y = y(:);

    y0 = y(1);
    yss_sim = y(end);

    Delta_y = yss_teorico - y0;

    banda = 0.05 * abs(Delta_y);

    lim_sup = yss_teorico + banda;
    lim_inf = yss_teorico - banda;

    idx_fuera = find(y > lim_sup | y < lim_inf);

    if isempty(idx_fuera)
        Ts_5 = 0;
    elseif idx_fuera(end) < length(t)
        Ts_5 = t(idx_fuera(end) + 1);
    else
        Ts_5 = NaN;
    end

    y_10 = y0 + 0.10 * Delta_y;
    y_90 = y0 + 0.90 * Delta_y;

    if Delta_y > 0
        idx_10 = find(y >= y_10, 1, 'first');
        idx_90 = find(y >= y_90, 1, 'first');
    else
        idx_10 = find(y <= y_10, 1, 'first');
        idx_90 = find(y <= y_90, 1, 'first');
    end

    if isempty(idx_10) || isempty(idx_90)
        Tr_10_90 = NaN;
    else
        Tr_10_90 = t(idx_90) - t(idx_10);
    end

    if Delta_y > 0
        pico = max(y);
        Mp = max(0, (pico - yss_teorico) / abs(Delta_y) * 100);
    else
        pico = min(y);
        Mp = max(0, (yss_teorico - pico) / abs(Delta_y) * 100);
    end

    essp = abs(yss_teorico - yss_sim);
end
